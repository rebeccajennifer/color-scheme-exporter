{
  "$schema"     : "vscode://schemas/color-theme"

, "colors":
  {
  //____________________________________________________________________
  // GENERAL
  //____________________________________________________________________
    "foreground"                                          : "#c6c6c6"
  , "editor.background"                                   : "#262626"
  , "editor.foreground"                                   : "#c6c6c6"

  //____________________________________________________________________
  // TERMINAL
  //____________________________________________________________________
  , "terminal.background"                                 : "#262626"
  , "terminal.foreground"                                 : "#c6c6c6"
  , "terminalCursor.background"                           : "#262626"
  , "terminalCursor.foreground"                           : "#5faf5f"
  //____________________________________________________________________
  , "terminal.ansiBlack"                                  : "#202020"
  , "terminal.ansiRed"                                    : "#af5f5f"
  , "terminal.ansiGreen"                                  : "#5faf5f"
  , "terminal.ansiYellow"                                 : "#afaf5f"
  , "terminal.ansiBlue"                                   : "#5f5faf"
  , "terminal.ansiMagenta"                                : "#af5faf"
  , "terminal.ansiCyan"                                   : "#5fafaf"
  , "terminal.ansiWhite"                                  : "#afafaf"
  //____________________________________________________________________
  , "terminal.ansiBrightBlack"                            : "#878787"
  , "terminal.ansiBrightRed"                              : "#d75f5f"
  , "terminal.ansiBrightGreen"                            : "#5fd75f"
  , "terminal.ansiBrightYellow"                           : "#d7d75f"
  , "terminal.ansiBrightBlue"                             : "#5f5fd7"
  , "terminal.ansiBrightMagenta"                          : "#d75fd7"
  , "terminal.ansiBrightCyan"                             : "#5fd7d7"
  , "terminal.ansiBrightWhite"                            : "#d7d7d7"

  // E.g. Background of hyperlink on hover in terminal
  , "terminal.hoverHighlightBackground"                   : "#d75fd760"

  // Dot left of command prompt
  , "terminalCommandDecoration.defaultBackground"         :"#5fafaf"
  , "terminalCommandDecoration.successBackground"         :"#5faf5f"
  , "terminalCommandDecoration.errorBackground"           :"#d75f5f"

  //____________________________________________________________________
  // BORDERS
  //____________________________________________________________________
  , "titleBar.border"                                     : "#c6c6c620"
  , "statusBar.border"                                    : "#c6c6c620"
  , "activityBar.border"                                  : "#c6c6c620"
  , "sideBar.border"                                      : "#c6c6c620"
  , "tab.border"                                          : "#262626"
  , "peekView.border"                                     : "#005f5f"

  // Border of focused element, e.g. active pane
  , "focusBorder"                                         : "#005f5f"

  // Border dividing panel from editor
  , "panel.border"                                        : "#c6c6c620"

  // Border under panel title
  , "panelTitle.border"                                   : "#c6c6c620"

  // E.g. Debug configuration selection
  , "dropdown.border"                                     : "#c6c6c620"

  // Border of text input fields, e.g. command palette, search
  , "input.border"                                        : "#c6c6c620"

  // Vertical line at certain character width in editor
  , "editorRuler.foreground"                              : "#c6c6c620"

  // Transparent
  , "editorStickyScroll.border"                           : "#00000000"
  , "panelStickyScroll.border"                            : "#00000000"

  //____________________________________________________________________
  // TITLE BAR - Main window title bar
  //____________________________________________________________________
  , "titleBar.activeBackground"                           : "#1c1c1c"
  , "titleBar.activeForeground"                           : "#bcbcbc"

  , "titleBar.inactiveBackground"                         : "#c6c6c620"
  , "titleBar.inactiveForeground"                         : "#c6c6c6"

  //____________________________________________________________________
  // STATUS BAR - Bottom of window
  //____________________________________________________________________
  , "statusBar.background"                                : "#1c1c1c"
  , "statusBar.foreground"                                : "#bcbcbc"
  , "statusBar.noFolderBackground"                        : "#5f345f"
  , "statusBarItem.remoteBackground"                      : "#5faf5f"
  , "statusBarItem.remoteForeground"                      : "#1c1c1c"

  , "statusBarItem.warningBackground"                     : "#d7d75f"
  , "statusBarItem.warningForeground"                     : "#262626"
  , "statusBarItem.errorBackground"                       : "#d75f5f"
  , "statusBarItem.errorForeground"                       : "#1c1c1c"

  //____________________________________________________________________
  // ACTIVITY BAR - Left of window
  //____________________________________________________________________
  , "activityBar.foreground"                              : "#bcbcbc"
  , "activityBar.background"                              : "#1c1c1c60"
  , "activityBar.activeBackground"                        : "#005f5f"
  , "activityBarBadge.background"                         : "#5faf5f"
  , "activityBarBadge.foreground"                         : "#1c1c1c"

  //____________________________________________________________________
  // SIDEBAR - Project explorer, etc.
  //____________________________________________________________________
  , "sideBar.background"                                  : "#1c1c1c20"
  , "sideBar.foreground"                                  : "#c6c6c6"
  , "sideBarStickyScroll.shadow"                          : "#202020"

  , "sideBarTitle.background"                             : "#262626"
  , "sideBarTitle.foreground"                             : "#bcbcbc"
  , "sideBarSectionHeader.background"                     : "#c6c6c610"
  , "sideBarSectionHeader.foreground"                     : "#bcbcbc"

  , "list.activeSelectionBackground"                      : "#005f5f"
  , "list.activeSelectionForeground"                      : "#bcbcbc"
  , "list.inactiveSelectionBackground"                    : "#c6c6c610"
  , "list.inactiveSelectionForeground"                    : "#c6c6c6"
  , "list.activeSelectionIconForeground"                  : "#c6c6c6"
  , "list.hoverBackground"                                : "#1c1c1c60"

  // Drag and drop files
  , "list.dropBackground"                                 : "#5f345f"
  , "list.dropBetweenBackground"                          : "#5f345f"

  , "list.highlightForeground"                            : "#5faf5f"
  , "list.focusBackground"                                : "#5f5fd780"
  , "list.invalidItemForeground"                          : "#d75f5f"

  //____________________________________________________________________
  // COMMAND PALETTE - Drop down when pressing Ctrl+P or Ctrl+Shift+P
  //____________________________________________________________________

  // Keyboard shortcut indicator in drop down command palette
  , "keybindingLabel.background"                          : "#c6c6c610"
  , "keybindingLabel.foreground"                          : "#c6c6c6"

  // E.g. 'other commands', 'recently opened ' in command palette
  , "pickerGroup.foreground"                              : "#5f5fd7"

  //____________________________________________________________________
  // MINIMAP - Mini version of code on right of window
  //____________________________________________________________________
  , "minimap.background"                                  : "#1c1c1c40"
  , "minimapGutter.addedBackground"                       : "#5faf5f"
  , "minimapGutter.deletedBackground"                     : "#d75f5f"
  , "minimapGutter.modifiedBackground"                    : "#afaf5f"

  //____________________________________________________________________
  // OVERVIEW RULER - Vertical bar to right of minimap
  //____________________________________________________________________
   , "editorOverviewRuler.addedForeground"                : "#5faf5f"
   , "editorOverviewRuler.modifiedForeground"             : "#afaf5f"
   , "editorOverviewRuler.deletedForeground"              : "#af5f5f"
   , "editorOverviewRuler.wordHighlightForeground"        : "#c6c6c620"

  //____________________________________________________________________
  // GUTTER - Line numbers, etc
  //____________________________________________________________________
  , "editorLineNumber.activeForeground"                   : "#d75f5f"
  , "editorLineNumber.foreground"                         : "#878787"

  //____________________________________________________________________
  // TABS
  //____________________________________________________________________
  , "tab.activeBackground"                                : "#262626"
  , "tab.activeForeground"                                : "#c6c6c6"
  , "tab.inactiveBackground"                              : "#c6c6c610"
  , "tab.inactiveForeground"                              : "#c6c6c680"
  , "tab.unfocusedActiveForeground"                       : "#5f5fd780"
  , "tab.unfocusedInactiveForeground"                     : "#878787"

  // Dead space to right of tabs
  , "editorGroupHeader.tabsBackground"                    : "#262626"

  //____________________________________________________________________
  // HIGHLIGHTING AND SELECTION
  //____________________________________________________________________
  , "editorCursor.background"                             : "#262626"
  , "editorCursor.foreground"                             : "#5faf5f"

  // Current line highlight
  , "editor.lineHighlightBackground"                      : "#1c1c1c60"

  , "editor.selectionBackground"                          : "#c6c6c620"
  , "editor.selectionForeground"                          : "#262626"
  , "selection.background"                                : "#004d5f80"

  // Needed for visual selection in vim
  , "editor.selectionHighlightBackground"                 : "#c6c6c610"

  // Occurrences of word under cursor
  , "editor.wordHighlightTextBackground"                  : "#c6c6c620"

  , "editor.wordHighlightBackground"                      : "#c6c6c610"

  , "editor.findMatchHighlightBackground"                 : "#004d5f80"
  , "editor.findMatchBackground"                          : "#004d5f80"

  //____________________________________________________________________
  // LINKS
  //____________________________________________________________________
  , "textLink.foreground"                                 : "#5f5fd7"
  , "textLink.activeForeground"                           : "#5f5faf"

  //____________________________________________________________________
  // TEXT INPUT FIELDS
  //____________________________________________________________________
  , "input.background"                                    : "#1c1c1c40"
  , "input.foreground"                                    : "#c6c6c6"
  , "input.placeholderForeground"                         : "#878787"

  // E.g. Commit message entry, command palette
  , "editor.placeholder.foreground"                       : "#878787"

  // E.g. Match case button in search
  , "inputOption.activeBackground"                        : "#005f5f"
  , "inputOption.activeForeground"                        : "#c6c6c6"
  , "inputOption.activeBorder"                            : "#c6c6c610"

  // Dropdown for command field
  , "editorWidget.background"                             : "#262626"
  , "editorWidget.border"                                 : "#c6c6c610"
  , "editorSuggestWidget.background"                      : "#1c1c1c"
  , "editorSuggestWidget.foreground"                      : "#c6c6c6"
  , "editorSuggestWidget.border"                          : "#c6c6c610"

  //____________________________________________________________________
  // STICKY SCROLL - keep current code context at top of file
  //____________________________________________________________________
  , "editorStickyScroll.background"                       : "#262626"
  , "editorStickyScrollHover.background"                  : "#1c1c1c"
  , "editorStickyScroll.shadow"                           : "#202020"
  , "panelStickyScroll.background"                        : "#1c1c1c"
  , "panelStickyScroll.shadow"                            : "#202020"

  //____________________________________________________________________
  // PEEK VIEW - Displayed with right-click and "Go to *"
  //____________________________________________________________________
  , "peekViewEditor.background"                           : "#004d5f60"
  , "peekViewEditor.matchHighlightBackground"             : "#004d5f80"
  , "peekViewResult.matchHighlightBackground"             : "#004d5f80"

  , "peekViewEditorStickyScroll.background"               : "#004d5f"
  , "peekViewEditorStickyScrollGutter.background"         : "#004d5f"

  , "peekViewTitleLabel.foreground"                       : "#c6c6c6"
  , "peekViewResult.fileForeground"                       : "#c6c6c6"
  , "peekViewResult.selectionBackground"                  : "#5f345f"
  , "peekViewResult.selectionForeground"                  : "#c6c6c6"

  // Peek View line number background
  //, "peekViewEditorGutter.background"                     :"#1c1c1c"

   // Text color of header in settings
  , "settings.headerForeground"                           : "#5f9696"

  //____________________________________________________________________
  // DROPDOWN
  //____________________________________________________________________
  , "dropdown.background"                                 : "#1c1c1c"
  , "dropdown.foreground"                                 : "#c6c6c6"
  , "dropdown.listBackground"                             : "#262626"

  //____________________________________________________________________
  // PANELS
  //____________________________________________________________________
  , "panel.background"                                    : "#262626"

  , "panelTitle.activeForeground"                         : "#bcbcbc"
  , "panelTitle.inactiveForeground"                       : "#c6c6c6"

  // Underline of active panel title - shows which panel is active
  , "panelTitle.activeBorder"                             : "#005f5f"
  //, "panelSectionHeader.background"                       : "#5faf5f"
  //, "panelTitleBadge.foreground"                          : "#262626"

  //____________________________________________________________________
  // BUTTONS & CHECKBOXES
  //____________________________________________________________________
  , "button.background"                                   : "#005f5f"
  , "button.foreground"                                   : "#c6c6c6"
  , "button.hoverBackground"                              : "#5f345f"

  // E.g. Checkboxes in settings
  , "checkbox.background"                                 : "#1c1c1c"
  , "checkbox.foreground"                                 : "#c6c6c6"

  //____________________________________________________________________
  // DEBUG
  //____________________________________________________________________

  // Breakpoint dot
  , "debugIcon.breakpointForeground"                      : "#d75f5f"
  , "debugIcon.breakpointDisabledForeground"              : "#d75f5f60"

  // Breakpoint arrow when stopped
  , "debugIcon.breakpointCurrentStackframeForeground"     : "#5faf5f"

  , "debugToolBar.background"                             : "#1c1c1c"
  , "debugIcon.startForeground"                           : "#5faf5f"
  , "debugIcon.stopForeground"                            : "#af5f5f"
  , "debugIcon.stepIntoForeground"                        : "#5f5faf"
  , "debugIcon.stepOverForeground"                        : "#5f5faf"
  , "debugIcon.stepOutForeground"                         : "#5f5faf"
  , "debugIcon.continueForeground"                        : "#af5faf"
  , "debugIcon.pauseForeground"                           : "#af5faf"
  , "debugIcon.restartForeground"                         : "#5fafaf"

  , "editor.inlineValuesBackground"                       : "#1c1c1c"
  , "editor.inlineValuesForeground"                       : "#afaf5f"
  , "editor.stackFrameHighlightBackground"                : "#1c1c1c"
  , "statusBar.debuggingBackground"                       : "#d7d75f"
  , "statusBar.debuggingForeground"                       : "#1c1c1c"

  // Debug exception
  , "debugExceptionWidget.border"                         : "#d75f5f"
  , "debugExceptionWidget.background"                     : "#d75f5f60"

  // Debug variables in sidebar
  , "debugConsole.infoForeground"                         : "#5f5faf"
  , "debugTokenExpression.boolean"                        : "#afaf5f"
  , "debugTokenExpression.number"                         : "#d75fd7"
  , "debugTokenExpression.string"                         : "#5fd7d7"
  , "debugTokenExpression.value"                          : "#c6c6c6"
  , "debugTokenExpression.error"                          : "#d75f5f"
  , "debugTokenExpression.name"                           : "#5faf5f"
  , "debugTokenExpression.type"                           : "#5f5faf"

  //____________________________________________________________________
  // SOURCE CONTROL
  //____________________________________________________________________
  , "gitDecoration.addedResourceForeground"               : "#5fd75f"
  , "gitDecoration.modifiedResourceForeground"            : "#afaf5f"
  , "gitDecoration.untrackedResourceForeground"           : "#af5faf"
  , "gitDecoration.deletedResourceForeground"             : "#d75f5f"
  , "gitDecoration.renamedResourceForeground"             : "#d7d75f"
  , "gitDecoration.conflictingResourceForeground"         : "#d75f5f"
  , "gitDecoration.stageDeletedResourceForeground"        : "#d75f5f"
  , "gitDecoration.stageModifiedResourceForeground"       : "#afaf5f"
  , "gitDecoration.submoduleResourceForeground"           : "#5fafaf"
  , "gitDecoration.ignoredResourceForeground"             : "#c6c6c680"

  // Vertical bar in gutter showing where line was added
  , "editorGutter.addedBackground"                        : "#5faf5f"
  // After staging - vertical bar in gutter where line was added
  , "editorGutter.addedSecondaryBackground"               : "#5faf5f"

  , "editorGutter.modifiedBackground"                     : "#afaf5f"
  , "editorGutter.modifiedSecondaryBackground"            : "#afaf5f"

  // Triangle pointing where line was deleted
  , "editorGutter.deletedBackground"                      : "#d75f5f"

  // After staging - vertical bar in gutter where line was deleted
  , "editorGutter.deletedSecondaryBackground"             : "#d7d75f"

  , "scmGraph.foreground1"                                : "#afaf5f"
  , "scmGraph.historyItemBaseRefColor"                    : "#af5f5f"
  , "scmGraph.historyItemRefColor"                        : "#5fd7d7"
  , "scmGraph.historyItemRemoteRefColor"                  : "#af5f5f"
  , "scmGraph.historyItemHoverLabelForeground"            : "#262626"

  , "diffEditor.insertedLineBackground"                   : "#5fd75f10"
  , "diffEditor.insertedTextBackground"                   : "#5fd75f20"
  , "diffEditorGutter.insertedLineBackground"             : "#5faf5f"
  , "diffEditorOverview.insertedForeground"               : "#5faf5f"
  , "diffEditor.insertedTextBorder"                       : "#00000000"

  , "diffEditor.removedLineBackground"                    : "#d75f5f10"
  , "diffEditor.removedTextBackground"                    : "#d75f5f20"
  , "diffEditorGutter.removedLineBackground"              : "#d75f5f"
  , "diffEditorOverview.removedForeground"                : "#d75f5f"
  , "diffEditor.removedTextBorder"                        : "#00000000"
  //, "inlineEdit.modifiedChangedLineBackground"            : "#d75f5f20"
  //, "inlineEdit.originalChangedLineBackground"            : "#d7d75f20"

  , "scmGraph.historyItemHoverDefaultLabelBackground"     : "#5faf5f"
  , "scmGraph.historyItemHoverDefaultLabelForeground"     : "#262626"
  , "scmGraph.foreground2"                                : "#af5faf"
  , "scmGraph.foreground3"                                : "#afaf5f"
  , "scmGraph.foreground4"                                : "#af5f5f"
  , "scmGraph.foreground5"                                : "#5f5faf"
  , "scmGraph.historyItemHoverAdditionsForeground"        : "#5faf5f"
  , "scmGraph.historyItemHoverDeletionsForeground"        : "#d75f5f"

  //____________________________________________________________________
  // ERRORS AND WARNINGS
  //____________________________________________________________________
  , "errorForeground"                                     : "#d75f5f"
  , "editorWarning.foreground"                            : "#d7d75f"
  , "editorError.foreground"                              : "#d75f5f"

  , "list.warningForeground"                              : "#d7d75f"
  , "list.errorForeground"                                : "#d75f5f"

  , "minimap.errorHighlight"                              : "#d75f5f"
  , "minimap.warningHighlight"                            : "#d7d75f"
  , "minimap.selectionHighlight"                          : "#5fafaf80"

  // Right of minimap
  , "editorOverviewRuler.errorForeground"                 : "#d75f5f"

  , "inputValidation.warningBackground"                   : "#d7d75f"
  , "inputValidation.warningForeground"                   : "#c6c6c6"
  , "inputValidation.warningBorder"                       : "#c6c6c6"
  , "inputValidation.errorBackground"                     : "#262626"
  , "inputValidation.errorForeground"                     : "#d75f5f"
  , "inputValidation.errorBorder"                         : "#d75f5f"

  , "problemsErrorIcon.foreground"                        : "#d75f5f"
  , "problemsWarningIcon.foreground"                      : "#d7d75f"
  , "problemsInfoIcon.foreground"                         : "#afaf5f"
  , "debugConsole.errorForeground"                        : "#d75f5f"
  , "debugConsole.warningForeground"                      : "#d7d75f"

  , "disabledForeground"                                  : "#87878780"
  , "list.deemphasizedForeground"                         : "#87878780"

  //____________________________________________________________________
  // ICONS
  //____________________________________________________________________

  // E.g. Settings icon in debug sidebar, add file icon in explorer
  , "icon.foreground"                                     : "#878787"
  , "editorLightBulb.foreground"                          : "#afaf5f"
  , "editorInfo.foreground"                               : "#5faf5f"

  , "symbolIcon.arrayForeground"                          : "#5fd75f"
  , "symbolIcon.booleanForeground"                        : "#c6c6c6"
  , "symbolIcon.classForeground"                          : "#5fafaf"
  //, "symbolIcon.colorForeground"                          : "#"
  , "symbolIcon.constantForeground"                       : "#d8d5d500"
  , "symbolIcon.constructorForeground"                    : "#af5faf"
  , "symbolIcon.enumeratorForeground"                     : "#af5faf"
  , "symbolIcon.enumeratorMemberForeground"               : "#afaf5f"
  //, "symbolIcon.eventForeground"                          : "#"
  , "symbolIcon.fieldForeground"                          : "#5f5faf"
  //, "symbolIcon.fileForeground"                           : "#"
  //, "symbolIcon.folderForeground"                         : "#"
  , "symbolIcon.functionForeground"                       : "#5fd7d7"
  //, "symbolIcon.interfaceForeground"                      : "#"
  //, "symbolIcon.keyForeground"                            : "#"
  //, "symbolIcon.keywordForeground"                        : "#"
  , "symbolIcon.methodForeground"                         : "#5fd7d7"
  , "symbolIcon.moduleForeground"                         : "#afaf5f"
  , "symbolIcon.namespaceForeground"                      : "#af5faf"
  //, "symbolIcon.nullForeground"                           : "#"
  //, "symbolIcon.numberForeground"                         : "#"
  //, "symbolIcon.objectForeground"                         : "#"
  //, "symbolIcon.operatorForeground"                       : "#"
  //, "symbolIcon.packageForeground"                        : "#"
  , "symbolIcon.propertyForeground"                       : "#5f5faf"
  //, "symbolIcon.referenceForeground"                      : "#"
  //, "symbolIcon.snippetForeground"                        : "#"
  , "symbolIcon.stringForeground"                         : "#d75fd7"
  , "symbolIcon.structForeground"                         : "#afaf5f"
  , "symbolIcon.textForeground"                           : "#d75fd7"
  //, "symbolIcon.typeParameterForeground"                  : "#"
  , "symbolIcon.unitForeground"                           : "#af5f5f"
  , "symbolIcon.variableForeground"                       : "#5f5faf"

  //____________________________________________________________________
  // MISC
  //____________________________________________________________________

  // Right-click menu
  , "menu.background"                                     : "#1c1c1c"

  //____________________________________________________________________
  // BRACKETS
  //____________________________________________________________________
  , "editorBracketHighlight.foreground1"                  : "#5fd75f"
  , "editorBracketHighlight.foreground3"                  : "#5fd7d7"
  , "editorBracketHighlight.foreground2"                  : "#af5f5f"
  , "editorBracketHighlight.unexpectedBracket.foreground" : "#d75f5f"

  //____________________________________________________________________
  // TESTING
  //____________________________________________________________________
  //  "list.filterMatchBackground"                          : "#d7d75f60"
  //, "panelSection.dropBackground"                         : "#5fd75f60"
  //, "list.filterMatchBackground"                          : "#FF0000"
  //, "list.inactiveFocusOutline"                           : "#FF0000"
  //, "editor.compositionBorder"                            : "#00010F"
  //, "editorActionList.background"                         : "#010FFF"
  //, "sideBar.dropBackground"                              : "#ff0000"
  //, "debugConsole.sourceForeground"                       : "#ff0000"
  //, "debugView.exceptionLabelBackground"                  : "#ffff00"
  //, "debugView.exceptionLabelForeground"                  : "#ff0000"
  //, "checkbox.border"                                     : "#010f00"
  //, "checkbox.selectBorder"                               : "#5faf5f"
  //, "checkbox.selectBackground"                           : "#ff0000"
  //, "checkbox.disabled.background"                        : "#ff0000"

  //____________________________________________________________________
  // Overridden by other properties
  //____________________________________________________________________
  //, "quickInput.background"                               : "#1c1c1c"
  //, "quickInputList.focusIconForeground"                  : "#bcbcbc"
  //, "quickInput.foreground"                               : "#c6c6c6"
  //, "settings.textInputBackground"                        : "#FFFF00"
  }

, "tokenColors":
  [ {}

  , { "name"  : "Foreground"
    , "scope": [ ""
      , "source"
      , "text.html" // Comment specifier
      , "variable.parameter"
      , "meta.body.function.definition"
      , "meta.function.definition"
      , "meta.function-call.arguments"
      , "punctuation"
      , "punctuation.definition.string"
      , "punctuation.definition.string.begin.python"
      , "punctuation.support.type.property-name"
      , "punctuation.separator.arguments"
      , "punctuation.separator.array"
      , "punctuation.separator.dictionary.pair"
      , "punctuation.separator.key-value"             // class="value"
      , "string.interpolated"
      , ""
      ], "settings": { "foreground": "#c6c6c6" }
  }

  , { "name"  : "Foreground Bold"
    , "scope": [ ""
      , "keyword.control.ternary" // Java - : in Circle: "circle"
      , ""
      ], "settings": { "foreground": "#5faf5f" }
    }

  , { "name"  : "Color 1: Pink"
    , "scope" : [ ""
      , "entity.name.function.preprocessor"
      , "entity.name.operator"
      , "heading.1.markdown"
      , "heading.1.quarto"
      , "keyword.control"               // switch, case, break, if, for
      , "keyword.other.directive.using" // using a = float
      , "keyword.other.operator"
      , "keyword.other.using"
      , ""
      ] , "settings": { "foreground": "#af5f5f" }
    }

  , { "name"  : "Color 9: Pink Bold"
    , "scope" : [ ""
      , "invalid"
      , ""
      ], "settings": { "foreground": "#d75f5f" }
    }

  , { "name"  : "Color 2: Green"
    , "scope" : [ ""

      , "heading.3.markdown"
      , "heading.3.quarto"
      , "keyword.operator"
      , "keyword.operator.assignment"
      , "keyword.operator.comparison"
      , "punctuation.definition.constant"         // # in #ff0000
      , "punctuation.definition.link.description"
      , "punctuation.separator.annotation.result" // -> in def f() -> int:
      ]
    , "settings": { "foreground": "#5faf5f" }
    }

  , { "name"  : "Color 10: Green Bold"
    , "scope" : [ ""
      , "keyword.control.directive"
      , "keyword.control.import"
      , "keyword.other.export"
