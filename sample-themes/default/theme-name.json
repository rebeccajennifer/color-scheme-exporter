      , "entity.name.operator.custom-literal"
      , "keyword.other.unit"
      , "punctuation.separator.continuation.line"
      ], "settings": { "foreground": "#d7d75f" }
    }

 , { "name"  : "Color 4: Blue"
    , "scope" : [ ""
      //, "entity.name.variable"
      , "heading.4.markdown"
      , "heading.4.quarto"
      , "meta.member.access.python"
      , "markup.list.numbered"
      , "variable.other.object"
      , "variable.other.property" // b in a.b
      , "support.type.property-name"
      , ""
      ], "settings": { "foreground": "#5f5faf"}
    }

  , { "name"  : "Color 12: Blue Bold"
    , "scope" : [ ""
      , "constant.other.placeholder"
      , "entity.name.tag"
      , "entity.name.type.parameter"
      , "markup.underline.link.image"
      , "meta.definition.variable.name"
      , "meta.method.return-type"
      , "support.constant.color"                    // red
      , "support.constant.property-value"           // css none
      , "support.type"
      , "storage.type.built-in"                     // int
      , "storage.type.function"                     // def in python
      , "storage.type.primitive"                    // int
      , "storage.type.string"                       // f in f'string'
      , "storage.type.template.argument.typename"   // public
      , "support.variable"
      , ""
      ], "settings": { "foreground": "#5f5fd7" }
    }

  , { "name"  : "Color 5: Violet"
    , "scope": [ ""
      , "entity.name.scope-resolution"
      , "heading.5.markdown"
      , "heading.5.quarto"
      , "storage.type.class"
      , "storage.type.enum"
      , "storage.type.namespace.definition"
      , "storage.type.struct"
      , "storage.type.template"
      , "storage.type.enum.enum-key.class.cpp"
      , "variable.language.special.self"          // python
      , "variable.language.this"                  // java
      , "variable.other.constant"
      , "entity.name.namespace"
      , "keyword.control.import.shortcode"
      , ""
      ], "settings": { "foreground": "#af5faf" }
    }

  , { "name"  : "Color 13: Violet Bold"
    , "scope" : [ ""
      , "constant.numeric"
      , "constant.other.color.rgb-value"
      , "constant.other.rgb-value"
      , "string"
      , ""
      ], "settings": { "foreground": "#d75fd7" }
    }

  , { "name"  : "Color 6: Cyan"
    , "scope" : [ ""
      , "entity.name.type"
      , "entity.other"
      ]
    , "settings": { "foreground": "#5fafaf" }
    }

  , { "name"  : "Color 14: Cyan Bold"
    , "scope" : [ ""
      , "support.function"
      , "entity.name.function"
      , "meta.function-call"

      ], "settings": { "foreground": "#5fd7d7" }
    }

  , { "name"  : "Color 0: Grey"
    , "scope": [ ""
      , "comment"
      , "punctuation.definition.comment" // Comment specifier e.g. //
      , ""
      ], "settings": { "foreground": "#878787" }
    }

  , { "name"  : "CSS property value"
    , "scope" : [ ""
      , "support.constant.media-type"
