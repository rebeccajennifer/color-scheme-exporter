      , "storage.type.modifier"        // public
      , ""
      ]
    , "settings": { "foreground": "#5fd75f"}
    }

  , { "name"  : "Color 3: Yellow"
    , "scope" : [ ""
      , "constant.language"
      , "heading.2.markdown"
      , "heading.2.quarto"
      , "keyword"
      , "keyword.operator"
      , "keyword.operator.cast"                       // static_cast
      , "keyword.operator.delete"
      , "keyword.operator.new"
      , "meta.separator"
      , "punctuation.separator.continuation.line"
      , "storage.modifier"                            // const, static
      , "support.constant.font-name"
      , ""
      ], "settings": { "foreground": "#afaf5f"}
    }

  , { "name": "Color 11: Yellow Bold"
    , "scope": [""
      , "constant.character.escape"    // \n in "\n"
      , "constant.other.placeholder"   // %02X in string
